#!/bin/bash
#
# forge — spin up Claude Code agents in isolated git worktrees
#
# Usage:
#   forge new [type] <name> [--detach] [-- <command>]
#   forge ls
#   forge attach <name>
#   forge teardown <name> [--force]
#
# Types: feature (default), bug, experiment
#
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROJECTS_DIR="${FORGE_PROJECTS_DIR:-$HOME/projects}"

# ─── Helpers ──────────────────────────────────────────────

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g' | sed -E 's/^-+|-+$//g'
}

relative_time() {
  local diff=$(( $(date +%s) - $1 ))
  if   (( diff < 60 ));    then echo "just now"
  elif (( diff < 3600 ));  then echo "$(( diff / 60 ))m ago"
  elif (( diff < 86400 )); then echo "$(( diff / 3600 ))h ago"
  else                          echo "$(( diff / 86400 ))d ago"
  fi
}

detect_base_branch() {
  for b in develop main master; do
    git -C "$1" rev-parse --verify "$b" >/dev/null 2>&1 && echo "$b" && return
  done
  echo "main"
}

is_worktree() {
  local gitdir commondir
  gitdir=$(git -C "$1" rev-parse --git-dir 2>/dev/null)
  commondir=$(git -C "$1" rev-parse --git-common-dir 2>/dev/null)
  [[ -n "$gitdir" && -n "$commondir" && "$gitdir" != "$commondir" ]]
}

# Build tmux path→session map (called once, cached in variable)
TMUX_MAP=""
load_tmux_map() {
  [[ -n "$TMUX_MAP" ]] && return
  local sessions
  sessions=$(tmux ls -F '#{session_name}' 2>/dev/null) || return
  local result=""
  while IFS= read -r s; do
    [[ -n "$s" ]] || continue
    local p
    p=$(tmux display-message -t "$s:0.0" -p '#{pane_current_path}' 2>/dev/null) || continue
    [[ -n "$p" ]] && result+="${s}|${p}"$'\n'
  done <<< "$sessions"
  TMUX_MAP="$result"
}

# Find tmux session whose pane path is inside the given repo
tmux_session_for_path() {
  local repo="$1"
  load_tmux_map
  while IFS='|' read -r sess_name sess_path; do
    [[ -n "$sess_name" ]] || continue
    [[ "$sess_path" == "$repo" || "$sess_path" == "$repo"/* ]] && echo "$sess_name" && return
  done <<< "$TMUX_MAP"
}

# Enumerate all git repos under $PROJECTS_DIR (up to depth 3), output: label|path|type
find_all_repos() {
  [[ -d "$PROJECTS_DIR" ]] || return
  local seen=()

  # Use find instead of globs — single pass, configurable depth
  while IFS= read -r candidate; do
    git -C "$candidate" rev-parse --git-dir >/dev/null 2>&1 || continue

    local root
    root=$(git -C "$candidate" rev-parse --show-toplevel 2>/dev/null || echo "$candidate")

    # Dedup by resolved root
    local dup=false
    for s in "${seen[@]}"; do [[ "$root" == "$s" ]] && dup=true && break; done
    $dup && continue
    seen+=("$root")

    # Label: for worktrees, use the parent repo name; otherwise use relative path
    local label
    if is_worktree "$root"; then
      local common_dir
      common_dir=$(git -C "$root" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/.git$||')
      label=$(basename "$common_dir")
      echo "${label}|${root}|worktree"
    else
      local rel="${root#"$PROJECTS_DIR"/}"
      # Collapse to basename if it's a direct child
      [[ "$rel" != */* ]] && rel=$(basename "$root")
      echo "${rel}|${root}|repo"
    fi
  done < <(find "$PROJECTS_DIR" -mindepth 1 -maxdepth 3 -type d -not -path '*/node_modules/*' -not -path '*/.git/*' -not -name '.*' 2>/dev/null)
}

# Find a session by partial name match
find_session() {
  local search="$1" matches=()

  while IFS='|' read -r project path stype; do
    local branch
    branch=$(git -C "$path" branch --show-current 2>/dev/null || echo "")
    local full_label="${project} > ${branch}"

    if [[ "$branch" == "$search" || "$project" == "$search" ]]; then
      echo "$project|$path|$branch|$stype"
      return 0
    fi
    if [[ "$branch" == *"$search"* || "$project" == *"$search"* ]]; then
      matches+=("$project|$path|$branch|$stype")
    fi
  done < <(find_all_repos)

  case ${#matches[@]} in
    0) return 1 ;;
    1) echo "${matches[0]}"; return 0 ;;
    *)
      echo -e "${RED}Multiple matches for '${search}':${NC}" >&2
      for m in "${matches[@]}"; do
        IFS='|' read -r p _ b _ <<< "$m"
        echo "  $p > $b" >&2
      done
      echo "Be more specific." >&2
      return 1
      ;;
  esac
}

# ─── Commands ─────────────────────────────────────────────

cmd_new() {
  local detach=false command="" positional=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --detach) detach=true; shift ;;
      --) shift; command="$*"; break ;;
      -*) echo -e "${RED}Unknown flag $1${NC}"; exit 1 ;;
      *) positional+=("$1"); shift ;;
    esac
  done

  local wtype="feature" wname=""
  case ${#positional[@]} in
    0) echo -e "${RED}Name is required${NC}"; echo "Usage: forge new [type] <name>"; exit 1 ;;
    1) wname="${positional[0]}" ;;
    2) wtype="${positional[0]}"; wname="${positional[1]}" ;;
    *) echo -e "${RED}Too many arguments${NC}"; exit 1 ;;
  esac

  case "$wtype" in
    feature|bug|experiment) ;;
    *) echo -e "${RED}Invalid type '${wtype}'. Use: feature, bug, experiment${NC}"; exit 1 ;;
  esac

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo -e "${RED}Not in a git repository${NC}"; exit 1; }

  local project=$(basename "$repo_root")
  local base=$(detect_base_branch "$repo_root")
  local slug=$(slugify "$wname")
  local branch="${wtype}/${slug}"
  local wt_dir="$(dirname "$repo_root")/${project}-worktrees/${slug}"

  echo -e "🔥 ${GREEN}Forging ${branch}...${NC}"
  echo "  Project: ${project}"
  echo "  Branch:  ${branch}"
  echo "  Base:    ${base}"
  echo "  Path:    ${wt_dir}"
  echo ""

  # Pre-flight
  [[ -d "$wt_dir" ]] && { echo -e "${RED}Directory already exists: ${wt_dir}${NC}"; exit 1; }
  git -C "$repo_root" rev-parse --verify "$branch" >/dev/null 2>&1 && { echo -e "${RED}Branch already exists: ${branch}${NC}"; exit 1; }

  # Create worktree
  git -C "$repo_root" fetch origin "${base}:${base}" 2>/dev/null || true
  mkdir -p "$(dirname "$wt_dir")"
  git -C "$repo_root" worktree add -b "$branch" "$wt_dir" "$base"

  # Setup
  [[ -f "${repo_root}/package.json" ]] && { echo -e "${YELLOW}Running npm install...${NC}"; (cd "$wt_dir" && npm install); }
  [[ -f "${repo_root}/.env" ]] && cp "${repo_root}/.env" "${wt_dir}/.env" && echo "  Copied .env"
  [[ -f "${repo_root}/.mcp.json" ]] && cp "${repo_root}/.mcp.json" "${wt_dir}/.mcp.json" && echo "  Copied .mcp.json"

  # CLAUDE.local.md
  cat > "${wt_dir}/CLAUDE.local.md" <<EOF
# Worktree: ${wname}

- **Branch**: \`${branch}\`
- **Type**: ${wtype}
- **Project**: ${project}
- **Base**: \`${base}\`
- **Created**: $(date -u +"%Y-%m-%d %H:%M UTC")

This is an isolated git worktree. Changes here don't affect the main worktree.

When done: \`forge teardown ${branch}\`
EOF

  # Tmux
  if ! command -v tmux &>/dev/null; then
    echo -e "🔥 ${GREEN}Worktree ready (tmux not found)${NC}"
    echo "  cd ${wt_dir}"
    return
  fi

  [[ -n "$TMUX" && "$detach" == false ]] && { echo -e "${YELLOW}Inside tmux, creating detached session${NC}"; detach=true; }

  tmux new-session -d -s "$branch" -n "claude" -c "$wt_dir"
  if [[ -n "$command" ]]; then
    tmux send-keys -t "$branch:0" "claude --dangerously-skip-permissions '${command}'" C-m
  else
    tmux send-keys -t "$branch:0" "claude --dangerously-skip-permissions" C-m
  fi
  tmux new-window -t "$branch:1" -n "shell" -c "$wt_dir"
  tmux select-window -t "$branch:0"

  echo ""
  if [[ "$detach" == true ]]; then
    echo -e "🔥 ${GREEN}Forged ${branch} (detached)${NC}"
    echo "  To attach: forge attach ${slug}"
  else
    echo -e "🔥 ${GREEN}Forged ${branch}${NC}"
    tmux attach-session -t "$branch"
  fi
}

cmd_ls() {
  local lines=()

  while IFS='|' read -r project path stype; do
    local branch
    branch=$(git -C "$path" branch --show-current 2>/dev/null || echo "detached")

    local tmux_sess
    tmux_sess=$(tmux_session_for_path "$path")
    local status="💀 dead"
    [[ -n "$tmux_sess" ]] && status="🔥 alive"

    local mod
    mod=$(git -C "$path" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
    local files="clean"
    [[ "$mod" -gt 0 ]] && files="${mod} modified"

    local push="not pushed"
    if git -C "$path" rev-parse --verify "@{upstream}" >/dev/null 2>&1; then
      local ahead
      ahead=$(git -C "$path" log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
      [[ "$ahead" -gt 0 ]] && push="unpushed" || push="pushed"
    fi

    local ts
    ts=$(git -C "$path" log -1 --format=%ct 2>/dev/null || echo "0")
    local age="no commits"
    [[ "$ts" -gt 0 ]] && age="last commit $(relative_time "$ts")"

    local alive_key=0
    [[ -n "$tmux_sess" ]] && alive_key=1
    lines+=("${alive_key}|${ts}|${project} > ${branch} - ${status} - ${files} (${push}) - ${age}")
  done < <(find_all_repos)

  [[ ${#lines[@]} -eq 0 ]] && { echo "No repos found."; return; }
  printf '%s\n' "${lines[@]}" | sort -t'|' -k1 -nr -k2 -nr | cut -d'|' -f3-
}

cmd_attach() {
  [[ -z "$1" ]] && { echo -e "${RED}Name is required${NC}"; echo "Run 'forge ls' to see sessions."; exit 1; }

  local match
  match=$(find_session "$1") || { echo -e "${RED}No session matching '$1'${NC}"; exit 1; }
  IFS='|' read -r project path branch stype <<< "$match"

  local tmux_sess
  tmux_sess=$(tmux_session_for_path "$path")
  [[ -z "$tmux_sess" ]] && { echo -e "${RED}No tmux session for ${branch}${NC}"; echo "  cd ${path} && claude"; exit 1; }

  echo -e "🔥 ${GREEN}Attaching to ${branch}...${NC}"
  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$tmux_sess"
  else
    tmux attach-session -t "$tmux_sess"
  fi
}

cmd_teardown() {
  local force=false search=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true; shift ;;
      -*) echo -e "${RED}Unknown flag $1${NC}"; exit 1 ;;
      *) search="$1"; shift ;;
    esac
  done

  [[ -z "$search" ]] && { echo -e "${RED}Name is required${NC}"; exit 1; }

  local match
  match=$(find_session "$search") || { echo -e "${RED}No session matching '${search}'${NC}"; exit 1; }
  IFS='|' read -r project path branch stype <<< "$match"

  [[ "$stype" != "worktree" ]] && { echo -e "${RED}${branch} is not a worktree${NC}"; exit 1; }

  # Safety check
  if [[ "$force" == false ]]; then
    local issues=()
    local n

    n=$(git -C "$path" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
    [[ "$n" -gt 0 ]] && issues+=("${n} unstaged changes")

    n=$(git -C "$path" diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
    [[ "$n" -gt 0 ]] && issues+=("${n} uncommitted staged changes")

    n=$(git -C "$path" ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
    [[ "$n" -gt 0 ]] && issues+=("${n} untracked files")

    if git -C "$path" rev-parse --verify "@{upstream}" >/dev/null 2>&1; then
      n=$(git -C "$path" log --oneline "@{upstream}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
    else
      local base
      base=$(detect_base_branch "$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/.git$||')")
      n=$(git -C "$path" log --oneline "${base}..HEAD" 2>/dev/null | wc -l | tr -d ' ')
    fi
    [[ "$n" -gt 0 ]] && issues+=("${n} unpushed commits")

    if [[ ${#issues[@]} -gt 0 ]]; then
      echo -e "⛔ ${RED}${branch} has $(IFS=' and '; echo "${issues[*]}")!${NC}"
      echo "Use --force to remove anyway."
      exit 1
    fi
  fi

  echo -e "💀 ${YELLOW}Tearing down ${branch}...${NC}"

  # Kill tmux
  local tmux_sess
  tmux_sess=$(tmux_session_for_path "$path")
  [[ -n "$tmux_sess" ]] && tmux kill-session -t "$tmux_sess" 2>/dev/null && echo "  → killed tmux session"

  # Remove worktree + branch
  local repo_root
  repo_root=$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | sed 's|/.git$||')
  git worktree remove --force "$path" 2>/dev/null && echo "  → removed worktree"
  git -C "$repo_root" branch -D "$branch" 2>/dev/null && echo "  → deleted branch"
  git -C "$repo_root" worktree prune 2>/dev/null

  echo -e "✨ ${GREEN}Gone!${NC}"
}

# ─── Main ─────────────────────────────────────────────────

case "${1:-}" in
  new)      shift; cmd_new "$@" ;;
  ls)       cmd_ls ;;
  attach)   shift; cmd_attach "$@" ;;
  teardown) shift; cmd_teardown "$@" ;;
  help|-h|--help|"")
    cat <<'USAGE'
forge — spin up Claude Code agents in isolated git worktrees

Usage:
  forge new [type] <name> [--detach] [-- <command>]
  forge ls
  forge attach <name>
  forge teardown <name> [--force]

Types: feature (default), bug, experiment
USAGE
    ;;
  *) echo -e "${RED}Unknown command '$1'. Run 'forge help'.${NC}"; exit 1 ;;
esac
